<?xml version="1.0" encoding="UTF-8"?>
 <beans xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="http://www.springframework.org/schema/beans"
    xmlns:context="http://www.springframework.org/schema/context"
    xmlns:mvc="http://www.springframework.org/schema/mvc"
    xsi:schemaLocation="http://www.springframework.org/schema/beans 
    http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
    http://www.springframework.org/schema/context 
    http://www.springframework.org/schema/context/spring-context-3.0.xsd">

<!-- bean tag for object creation 
<bean  id="Obj Name" class="classname">
	<property name="variablename"  value="val"/>
</bean>
-->
<!-- Setter Dependency Injection -->
<bean id="stdObj"  class="coms.beans.Student">
	<property name="rollno"  value="101" />
	<property name="sname"  value="Nagini" />
	<property name="course"  value="JavaFSD" />
	<property name="fees"  value="25000.00" />
</bean>

<!-- Constructor Dependency Injection -->
<bean id="perObj"   class="coms.beans.Person">
	<constructor-arg name="pname" value="Naresh Kumar"/>
	<constructor-arg name="email" value="naresh@gmail.com"/>
</bean>

</beans>